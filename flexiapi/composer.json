{
    "name": "bc/flexiapi",
    "type": "project",
    "description": "FlexiAPI",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "awobaz/compoships": "^3.0.2",
        "codercat/jwk-to-pem": "^1.1",
        "comcast/php-legal-licenses": "^2.2",
        "doctrine/dbal": "^4.4",
        "endroid/qr-code": "^5.1",
        "fakerphp/faker": "^1.24.1",
        "hisorange/browser-detect": "^5.0.3",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^3.0.2",
        "lcobucci/jwt": "^4.3",
        "namoshek/laravel-redis-sentinel": "^1.3",
        "ovh/ovh": "^3.5",
        "parsedown/laravel": "^1.2.1",
        "phpunit/phpunit": "^11.0",
        "propaganistas/laravel-phone": "^6.0.3",
        "react/socket": "^1.17",
        "respect/validation": "^2.4.12",
        "sabre/vobject": "^4.6",
        "scyllaly/hcaptcha": "^4.5"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.5",
        "phpmd/phpmd": "^2.15",
        "squizlabs/php_codesniffer": "^3.13.5"
    },
    "config": {
        "platform": {
            "php": "8.2"
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Tests\\": "tests/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "post-update-cmd": [
            "@php vendor/bin/php-legal-licenses generate"
        ]
    }
}
